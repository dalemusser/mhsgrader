# MHSGrader Environment Variables
# Copy to .env and adjust as needed

# MongoDB connection (DocumentDB in production)
MHSGRADER_MONGO_URI=mongodb://user:password@docdb-cluster.region.docdb.amazonaws.com:27017/?ssl=true&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false
MHSGRADER_MONGO_DATABASE=stratalog

# Grader settings
MHSGRADER_GAME=mhs
MHSGRADER_SCAN_INTERVAL=5s
MHSGRADER_BATCH_SIZE=500
MHSGRADER_ACTIVE_GAP_THRESHOLD=2m
MHSGRADER_BACKFILL_MODE=false

# Logging
WAFFLE_LOG_LEVEL=info
WAFFLE_ENV=prod
